# ===========================================
# O'zbekiston Muzeylari Platform — Environment
# ===========================================

# Database (PostgreSQL 16)
DATABASE_URL=postgresql://muzeylari:muzeylari_secret@localhost:5432/muzeylari?schema=public
POSTGRES_USER=muzeylari
POSTGRES_PASSWORD=muzeylari_secret
POSTGRES_DB=muzeylari

# Redis
REDIS_URL=redis://localhost:6379

# JWT — App (device auth)
APP_JWT_SECRET=change-me-app-jwt-secret-min-32-chars
APP_JWT_EXPIRES_IN=365d

# JWT — Admin
ADMIN_JWT_SECRET=change-me-admin-jwt-secret-min-32-chars
ADMIN_JWT_EXPIRES_IN=15m
ADMIN_JWT_REFRESH_SECRET=change-me-admin-refresh-secret-min-32-chars
ADMIN_JWT_REFRESH_EXPIRES_IN=7d

# Flek SSO — accept JWTs minted by flek-monitor (status.flek.uz)
# Same secret must be set on the flek-monitor side as SSO_SECRETS={"mozey":"..."}
FLEK_SSO_SECRET=change-me-flek-sso-shared-secret-min-32-chars
FLEK_SSO_ALLOWED_ISS=flek-monitor
FLEK_SSO_ALLOWED_AUD=mozey
# Set to "true" to auto-create an Admin row on first Flek SSO login.
# Leave unset for stricter security: only emails already in the admin DB can SSO.
FLEK_SSO_AUTOPROVISION=false
FLEK_SSO_DEFAULT_ROLE=editor

# S3-Compatible Storage (MinIO / Cloudflare R2 / AWS S3)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=muzeylari
S3_PUBLIC_URL=http://localhost:9000/muzeylari

# Admin seed
ADMIN_SEED_EMAIL=admin@muzeylari.uz
ADMIN_SEED_PASSWORD=change-me-admin-password

# Application
NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# Landing / Admin URLs (for CORS and redirects)
ADMIN_URL=http://localhost:3001
LANDING_URL=http://localhost:3002
API_URL=http://localhost:3000
